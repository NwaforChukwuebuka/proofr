{
  "info": {
    "name": "PROOFR API",
    "description": "As-built PROOFR API collection.\n\n**Public / grading share — keep secrets out**\nShare this **collection only**. Do not publish environments filled with passwords, admin secrets, or tokens.\n\n**Getting bearer tokens**\n1. Set `merchantEmail` / `merchantPassword` and `lenderEmail` / `lenderPassword` (demo accounts, out-of-band).\n2. Run **Auth → Merchant login** or **Auth → Lender login** (`POST /api/auth/login`).\n3. Tokens are saved to `{{merchantAccessToken}}` / `{{lenderAccessToken}}` automatically.\n\nYou do **not** need Supabase URL or anon key — the server already has them.\n\n**Signup**\n- Merchants: `POST /api/merchants`, then Merchant login.\n- Lenders: no public signup; use a provisioned demo lender + Lender login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "merchantId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "loanId", "value": "" },
    { "key": "fraudFlagId", "value": "" },
    { "key": "apiClientId", "value": "" },
    { "key": "merchantAccessToken", "value": "" },
    { "key": "lenderAccessToken", "value": "" },
    { "key": "adminApiSecret", "value": "" },
    { "key": "publicApiKey", "value": "" },
    { "key": "merchantPhone", "value": "" },
    { "key": "merchantEmail", "value": "" },
    { "key": "merchantPassword", "value": "" },
    { "key": "lenderEmail", "value": "" },
    { "key": "lenderPassword", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "POST /api/auth/login — server uses Supabase anon config. Graders only need demo email/password.",
      "item": [
        {
          "name": "Merchant login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Merchant login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('merchantAccessToken', json.accessToken);",
                  "  if (json.merchantId) pm.environment.set('merchantId', json.merchantId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{merchantEmail}}\",\n  \"password\": \"{{merchantPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Returns accessToken. Saved as merchantAccessToken. Also sets merchantId when role is merchant."
          }
        },
        {
          "name": "Lender login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lender login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('lenderAccessToken', json.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{lenderEmail}}\",\n  \"password\": \"{{lenderPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Returns accessToken. Saved as lenderAccessToken."
          }
        },
        {
          "name": "Merchant signup then login (flow)",
          "description": "Run in order. Signup creates the account; login fills merchantAccessToken.",
          "item": [
            {
              "name": "1. POST /api/merchants (signup)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Merchant signup created', function () {",
                      "  pm.response.to.have.status(201);",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.merchantId).to.be.a('string').and.not.empty;",
                      "  pm.environment.set('merchantId', json.merchantId);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"{{merchantPhone}}\",\n  \"email\": \"{{merchantEmail}}\",\n  \"password\": \"{{merchantPassword}}\",\n  \"businessName\": \"Test Suya Spot\",\n  \"bvnOrNin\": \"12345678901\",\n  \"personalAccountNumber\": \"\",\n  \"businessStartDate\": \"\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/merchants", "host": ["{{baseUrl}}"], "path": ["api", "merchants"] },
                "description": "Creates auth user + merchant. Then run step 2."
              }
            },
            {
              "name": "2. Merchant login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Merchant login succeeded', function () {",
                      "  pm.response.to.have.status(200);",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                      "  pm.environment.set('merchantAccessToken', json.accessToken);",
                      "  if (json.merchantId) pm.environment.set('merchantId', json.merchantId);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{merchantEmail}}\",\n  \"password\": \"{{merchantPassword}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "login"]
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
          }
        }
      ]
    },
    {
      "name": "Merchants",
      "item": [
        {
          "name": "POST /api/merchants (signup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.merchantId) {",
                  "    pm.environment.set('merchantId', json.merchantId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{merchantPhone}}\",\n  \"email\": \"{{merchantEmail}}\",\n  \"password\": \"{{merchantPassword}}\",\n  \"businessName\": \"Test Suya Spot\",\n  \"bvnOrNin\": \"12345678901\",\n  \"personalAccountNumber\": \"\",\n  \"businessStartDate\": \"\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/merchants", "host": ["{{baseUrl}}"], "path": ["api", "merchants"] },
            "description": "Merchant signup. Saves `merchantId` on 201. Does not return a JWT — run **Auth → Merchant login** afterward."
          }
        },
        {
          "name": "POST /api/merchants/:id/approve (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-admin-secret", "value": "{{adminApiSecret}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "approve"]
            }
          }
        },
        {
          "name": "GET /api/merchants/:id/revenue",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/revenue?granularity=daily",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "revenue"],
              "query": [{ "key": "granularity", "value": "daily", "description": "daily|monthly" }]
            }
          }
        },
        {
          "name": "POST /api/merchants/:id/report (generate)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "report"]
            }
          }
        },
        {
          "name": "GET /api/merchants/:id/report (latest, bearer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "report"]
            }
          }
        },
        {
          "name": "GET /api/merchants/:id/report (by reportId, no auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/report?reportId={{reportId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "report"],
              "query": [{ "key": "reportId", "value": "{{reportId}}" }]
            }
          }
        },
        {
          "name": "GET /api/merchants/:id/loans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/loans",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "loans"]
            }
          }
        },
        {
          "name": "POST /api/merchants/:id/reject (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-admin-secret", "value": "{{adminApiSecret}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "reject"]
            }
          }
        },
        {
          "name": "GET /api/merchants/:id/public-api-consent",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/public-api-consent",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "public-api-consent"]
            }
          }
        },
        {
          "name": "POST /api/merchants/:id/public-api-consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{merchantAccessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"consent\": true\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}/public-api-consent",
              "host": ["{{baseUrl}}"],
              "path": ["api", "merchants", "{{merchantId}}", "public-api-consent"]
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "POST /api/webhooks/monnify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "monnify-signature", "value": "<hex hmac-sha512 of raw body using MONNIFY_SECRET_KEY>" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"SUCCESSFUL_TRANSACTION\",\n  \"eventData\": {\n    \"product\": { \"type\": \"RESERVED_ACCOUNT\", \"reference\": \"PROOFR-<merchantId>\" },\n    \"transactionReference\": \"MNFY|79|20260719222030|000096\",\n    \"paymentReference\": \"MNFY|79|20260719222030|000096\",\n    \"amountPaid\": 30000,\n    \"totalPayable\": 30000,\n    \"paymentStatus\": \"PAID\",\n    \"paymentMethod\": \"ACCOUNT_TRANSFER\",\n    \"destinationAccountInformation\": { \"accountNumber\": \"4003488430\", \"bankCode\": \"035\", \"bankName\": \"Wema bank\" },\n    \"paymentSourceInformation\": [\n      { \"accountName\": \"Monnify Limited\", \"accountNumber\": \"2048714015\", \"bankCode\": \"057\", \"amountPaid\": 30000, \"sessionId\": \"...\" }\n    ],\n    \"customer\": { \"name\": \"suya joint\", \"email\": \"chukwuebuka.nwaforx@gmail.com\" }\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/webhooks/monnify", "host": ["{{baseUrl}}"], "path": ["api", "webhooks", "monnify"] },
            "description": "monnify-signature must be recomputed locally (hex HMAC-SHA512 of the exact raw request body using MONNIFY_SECRET_KEY) whenever the body is edited — Postman cannot compute this automatically without a pre-request script."
          }
        }
      ]
    },
    {
      "name": "Lenders",
      "description": "All lender routes need `{{lenderAccessToken}}` from **Auth → Lender login**. There is no public `POST /api/lenders` signup — provision lenders in Supabase, then log in.",
      "item": [
        {
          "name": "GET /api/lenders/search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/lenders/search?query=suya",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lenders", "search"],
              "query": [{ "key": "query", "value": "suya" }]
            }
          }
        },
        {
          "name": "GET /api/lenders/merchants/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/lenders/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lenders", "merchants", "{{merchantId}}"]
            }
          }
        },
        {
          "name": "GET /api/lenders/api-keys (list)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/lenders/api-keys", "host": ["{{baseUrl}}"], "path": ["api", "lenders", "api-keys"] }
          }
        },
        {
          "name": "POST /api/lenders/api-keys (generate)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Investor demo key\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/lenders/api-keys", "host": ["{{baseUrl}}"], "path": ["api", "lenders", "api-keys"] },
            "description": "Response includes apiKey (the raw key) exactly once — copy it out, it is never returned again."
          }
        },
        {
          "name": "POST /api/lenders/api-keys/:id/revoke",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/lenders/api-keys/{{apiClientId}}/revoke",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lenders", "api-keys", "{{apiClientId}}", "revoke"]
            }
          }
        }
      ]
    },
    {
      "name": "Loans",
      "item": [
        {
          "name": "POST /api/loans (create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const id = json.loanId || json.id;",
                  "  if (id) pm.environment.set('loanId', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"amount\": 90000\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/loans", "host": ["{{baseUrl}}"], "path": ["api", "loans"] }
          }
        },
        {
          "name": "POST /api/loans/:id/approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/loans/{{loanId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "loans", "{{loanId}}", "approve"]
            }
          }
        },
        {
          "name": "GET /api/loans/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{lenderAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/loans/{{loanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "loans", "{{loanId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /api/admin/fraud-queue",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-admin-secret", "value": "{{adminApiSecret}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/fraud-queue", "host": ["{{baseUrl}}"], "path": ["api", "admin", "fraud-queue"] }
          }
        },
        {
          "name": "POST /api/admin/fraud-flags/:id/override",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-admin-secret", "value": "{{adminApiSecret}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"clear\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/admin/fraud-flags/{{fraudFlagId}}/override",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "fraud-flags", "{{fraudFlagId}}", "override"]
            },
            "description": "action must be \"clear\" (false positive -> status: overridden) or \"confirm\" (real fraud -> stays open, reviewed_at set)."
          }
        },
        {
          "name": "GET /api/admin/loan-outcomes",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-admin-secret", "value": "{{adminApiSecret}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/loan-outcomes", "host": ["{{baseUrl}}"], "path": ["api", "admin", "loan-outcomes"] }
          }
        },
        {
          "name": "GET /api/admin/pending-merchants",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-admin-secret", "value": "{{adminApiSecret}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/pending-merchants", "host": ["{{baseUrl}}"], "path": ["api", "admin", "pending-merchants"] }
          }
        }
      ]
    },
    {
      "name": "Public API",
      "item": [
        {
          "name": "GET /api/public/score",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{publicApiKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/public/score?phone={{merchantPhone}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "score"],
              "query": [{ "key": "phone", "value": "{{merchantPhone}}" }]
            }
          }
        }
      ]
    }
  ]
}
