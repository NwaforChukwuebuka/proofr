# separate secret. Kept here only so a stale reference doesn't 500 on
# read; see handoff.md milestone 5 entry / lib/monnify.ts.
MONNIFY_WEBHOOK_SECRET=

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
